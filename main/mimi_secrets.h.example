/*
 * MimiClaw Build-time Secrets
 *
 * Copy this file to mimi_secrets.h and fill in your values.
 * mimi_secrets.h is gitignored — never commit it.
 *
 *   cp main/mimi_secrets.h.example main/mimi_secrets.h
 *
 * After any change, rebuild:
 *   idf.py fullclean && idf.py build
 */

#pragma once

/* WiFi */
#define MIMI_SECRET_WIFI_SSID           "your_wifi_ssid"
#define MIMI_SECRET_WIFI_PASS           "your_wifi_password"

/* Telegram Bot (get token from @BotFather) */
#define MIMI_SECRET_TG_TOKEN            ""

/* Discord Bot */
#define MIMI_SECRET_DISCORD_TOKEN       ""

/* LLM provider — pick one:
 *   provider = "openrouter"  model = "google/gemini-2.5-flash"  (free tier)
 *   provider = "gemini"      model = "gemini-2.0-flash"
 *   provider = "zhipu"       model = "GLM-4-FlashX-250414"
 *   provider = "anthropic"   model = "claude-3-haiku-20240307"
 *   provider = "openai"      model = "gpt-4o-mini"
 */
#define MIMI_SECRET_API_KEY             ""
#define MIMI_SECRET_MODEL               "google/gemini-2.5-flash"
#define MIMI_SECRET_MODEL_PROVIDER      "openrouter"

/* HTTP Proxy (leave empty if not needed) */
#define MIMI_SECRET_PROXY_HOST          ""
#define MIMI_SECRET_PROXY_PORT          ""
#define MIMI_SECRET_PROXY_TYPE          ""   /* "http" or "socks5" */

/* Web Search — Tavily (https://tavily.com, 1000 free/month, no card needed)
 *              or Brave Search (https://api.search.brave.com)
 * Key prefix "tvly-" auto-selects Tavily, otherwise Brave is used.
 */
#define MIMI_SECRET_SEARCH_KEY          ""

/* Deepgram ASR — speech-to-text (https://deepgram.com, free tier available) */
#define MIMI_SECRET_DEEPGRAM_KEY        ""

/* WeCom (Enterprise WeChat) Robot Webhook */
#define MIMI_SECRET_WECOM_WEBHOOK       ""

/* Optional Discord Bridge */
#define MIMI_SECRET_BRIDGE_URL          ""
#define MIMI_SECRET_BRIDGE_DEVICE_ID    ""
#define MIMI_SECRET_BRIDGE_DEVICE_TOKEN ""
